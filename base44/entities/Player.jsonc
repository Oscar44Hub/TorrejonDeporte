{
  "name": "Player",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Nombre completo del jugador"
    },
    "team_id": {
      "type": "string",
      "description": "ID del equipo"
    },
    "team_name": {
      "type": "string",
      "description": "Nombre del equipo (desnormalizado)"
    },
    "league_id": {
      "type": "string"
    },
    "league_name": {
      "type": "string"
    },
    "sport_name": {
      "type": "string"
    },
    "dni": {
      "type": "string",
      "description": "DNI/NIE del jugador"
    },
    "birth_date": {
      "type": "string",
      "format": "date"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "jersey_number": {
      "type": "number",
      "description": "N\u00famero de camiseta"
    },
    "position": {
      "type": "string",
      "description": "Posici\u00f3n o rol en el equipo"
    },
    "status": {
      "type": "string",
      "enum": [
        "pendiente",
        "activo",
        "sancionado",
        "lesionado",
        "baja"
      ],
      "default": "pendiente"
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "description": "Si el jugador ha confirmado su inscripci\u00f3n"
    },
    "rejection_pending": {
      "type": "boolean",
      "default": false,
      "description": "Si el jugador ha rechazado su inscripci\u00f3n"
    },
    "rejection_expiry_date": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha hasta la que estar\u00e1 en baja por rechazo"
    },
    "confirmation_token": {
      "type": "string",
      "description": "Token \u00fanico para el enlace de confirmaci\u00f3n"
    },
    "photo_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "reminder_sent": {
      "type": "boolean",
      "default": false
    },
    "reminder_sent_date": {
      "type": "string",
      "format": "date-time"
    },
    "reminder_sent_expired": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "full_name",
    "team_id",
    "dni"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.delegate_email": "{{user.email}}"
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "arbitro"
          }
        },
        {
          "data.delegate_email": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.delegate_email": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "data.delegate_email": "{{user.email}}"
        }
      ]
    }
  }
}